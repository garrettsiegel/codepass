{
  "fallbackOn": [
    "rate_limit",
    "quota_exceeded",
    "auth_error",
    "timeout",
    "command_not_found",
    "nonzero_exit"
  ],
  "context": {
    "maxDiffChars": 20000
  },
  "logs": {
    "sessionsDir": ".keepitmovin/sessions"
  },
  "updates": {
    "checkOnStart": true,
    "mode": "prompt",
    "includeDisabledProviders": false
  },
  "routing": {
    "enabled": false,
    "promptForTask": true,
    "allowOverride": true,
    "askOutcome": true,
    "telemetry": true
  },
  "harness": {
    "setupComplete": false,
    "providerOrder": [
      "claude",
      "codex",
      "kimi",
      "antigravity",
      "opencode",
      "grok",
      "cursor",
      "copilot",
      "ollama"
    ],
    "transcriptLimitChars": 80000,
    "handoffPath": ".keepitmovin/current/handoff.md",
    "handoffArchiveDir": ".keepitmovin/handoffs",
    "manualSwitchKey": "ctrl-]",
    "idleTimeoutMs": 0,
    "autoAppendCheckpoints": true,
    "usageProbe": {
      "enabled": true,
      "thresholdPercent": 95,
      "pollIntervalMs": 30000
    },
    "handoffRefresh": {
      "enabled": true,
      "intervalMs": 60000,
      "nudge": {
        "enabled": true,
        "staleAfterMs": 300000,
        "idleForMs": 10000,
        "minTranscriptGrowthChars": 2000
      }
    },
    "providers": [
      {
        "name": "claude",
        "label": "Claude Code",
        "enabled": true,
        "command": "claude",
        "args": [
          "{{sessionPrompt}}"
        ],
        "handoffArgs": [
          "{{handoffPrompt}}"
        ],
        "integrationType": "pty",
        "controllable": true,
        "limitPatterns": [
          "5-hour limit reached",
          "upgrade to increase your usage limit",
          "you've reached your usage limit",
          "selected model is at capacity"
        ]
      },
      {
        "name": "codex",
        "label": "Codex",
        "enabled": true,
        "command": "codex",
        "args": [
          "{{sessionPrompt}}"
        ],
        "handoffArgs": [
          "{{handoffPrompt}}"
        ],
        "integrationType": "pty",
        "controllable": true,
        "limitPatterns": [
          "you've hit your usage limit",
          "you have hit your usage limit",
          "reached your usage limit"
        ],
        "usageProbe": {
          "kind": "codex-session-files"
        }
      },
      {
        "name": "kimi",
        "label": "Kimi CLI",
        "enabled": true,
        "command": "kimi",
        "args": [],
        "handoffArgs": [],
        "integrationType": "pty_with_bootstrap_input",
        "bootstrapInput": "Read the keepitmovin handoff at {{handoffPath}} and continue the session (keep that file updated as you work).\n",
        "handoffBootstrapInput": "Read the keepitmovin handoff at {{handoffPath}} first, then continue from where the previous tool left off.\n",
        "controllable": true,
        "limitPatterns": [
          "[provider.rate_limit]",
          "membership expired, please renew your plan",
          "rate_limit_reached_error",
          "exceeded_current_quota_error",
          "engine_overloaded_error",
          "request reached organization",
          "is suspended due to insufficient balance",
          "reached your usage limit for this billing cycle"
        ]
      },
      {
        "name": "antigravity",
        "label": "Google Antigravity",
        "enabled": true,
        "command": "agy",
        "args": [
          "--prompt-interactive",
          "{{sessionPrompt}}"
        ],
        "handoffArgs": [
          "--prompt-interactive",
          "{{handoffPrompt}}"
        ],
        "integrationType": "pty",
        "controllable": true,
        "limitPatterns": [
          "individual quota reached",
          "the model api is currently overloaded",
          "our servers are experiencing high traffic right now"
        ]
      },
      {
        "name": "opencode",
        "label": "opencode",
        "enabled": true,
        "command": "opencode",
        "args": [
          "{{cwd}}",
          "--prompt",
          "{{sessionPrompt}}"
        ],
        "handoffArgs": [
          "{{cwd}}",
          "--prompt",
          "{{handoffPrompt}}"
        ],
        "integrationType": "pty",
        "controllable": true,
        "limitPatterns": [
          "provider is overloaded",
          "free usage exceeded, subscribe to go",
          "usage limit reached",
          "subscription quota exceeded",
          "gemini is way too hot right now"
        ]
      },
      {
        "name": "grok",
        "label": "Grok Build",
        "enabled": true,
        "command": "grok",
        "args": [
          "{{sessionPrompt}}"
        ],
        "handoffArgs": [
          "{{handoffPrompt}}"
        ],
        "integrationType": "pty",
        "controllable": true,
        "limitPatterns": [
          "hit the rate limit for your plan",
          "reached your free grok build usage limit",
          "free-usage-exhausted",
          "you hit your free usage limit",
          "you hit your weekly limit",
          "usage balance exhausted",
          "out of credits",
          "spending cap"
        ]
      },
      {
        "name": "cursor",
        "label": "Cursor Agent",
        "enabled": true,
        "command": "agent",
        "args": [
          "{{sessionPrompt}}"
        ],
        "handoffArgs": [
          "{{handoffPrompt}}"
        ],
        "integrationType": "pty",
        "controllable": true,
        "limitPatterns": [
          "you've hit your usage limit",
          "your usage limits will reset when your monthly cycle ends",
          "you've hit your free requests limit",
          "we're experiencing high demand"
        ]
      },
      {
        "name": "copilot",
        "label": "GitHub Copilot CLI",
        "enabled": true,
        "command": "copilot",
        "args": [],
        "handoffArgs": [],
        "integrationType": "pty_with_bootstrap_input",
        "bootstrapInput": "Read the keepitmovin handoff at {{handoffPath}} and continue the session (keep that file updated as you work).\n",
        "handoffBootstrapInput": "Read the keepitmovin handoff at {{handoffPath}} first, then continue from where the previous tool left off.\n",
        "controllable": true,
        "limitPatterns": [
          "hit a rate limit that restricts the number of copilot model requests",
          "reached your weekly rate limit",
          "exceeded your copilot token usage",
          "you have no quota",
          "quota_exceeded"
        ]
      },
      {
        "name": "ollama",
        "label": "Ollama",
        "enabled": true,
        "command": "ollama",
        "args": [
          "run",
          "llama3.2"
        ],
        "handoffArgs": [
          "run",
          "llama3.2"
        ],
        "integrationType": "pty_with_bootstrap_input",
        "bootstrapInput": "{{sessionPrompt}}\n",
        "handoffBootstrapInput": "{{handoffPrompt}}\n",
        "controllable": true
      }
    ]
  }
}
