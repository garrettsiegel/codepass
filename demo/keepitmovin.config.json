{
  "updates": {
    "checkOnStart": false,
    "mode": "off"
  },
  "harness": {
    "setupComplete": true,
    "providerOrder": [
      "demo-a",
      "demo-b"
    ],
    "providers": [
      {
        "name": "demo-a",
        "label": "Claude Code",
        "enabled": true,
        "command": "bash",
        "args": [
          "agent.sh",
          "claude"
        ],
        "handoffArgs": [
          "agent.sh",
          "claude"
        ],
        "integrationType": "pty",
        "controllable": true,
        "limitPatterns": [
          "Claude usage limit reached"
        ]
      },
      {
        "name": "demo-b",
        "label": "Codex",
        "enabled": true,
        "command": "bash",
        "args": [
          "agent.sh",
          "codex"
        ],
        "handoffArgs": [
          "agent.sh",
          "codex"
        ],
        "integrationType": "pty",
        "controllable": true
      },
      {
        "name": "claude",
        "label": "Claude Code",
        "enabled": false,
        "command": "claude",
        "args": [
          "{{sessionPrompt}}"
        ],
        "handoffArgs": [
          "{{handoffPrompt}}"
        ],
        "integrationType": "pty",
        "controllable": true,
        "limitPatterns": [
          "5-hour limit reached",
          "upgrade to increase your usage limit",
          "you've reached your usage limit",
          "selected model is at capacity"
        ]
      },
      {
        "name": "codex",
        "label": "Codex",
        "enabled": false,
        "command": "codex",
        "args": [
          "{{sessionPrompt}}"
        ],
        "handoffArgs": [
          "{{handoffPrompt}}"
        ],
        "integrationType": "pty",
        "controllable": true,
        "limitPatterns": [
          "you've hit your usage limit",
          "you have hit your usage limit",
          "reached your usage limit"
        ],
        "usageProbe": {
          "kind": "codex-session-files"
        }
      },
      {
        "name": "kimi",
        "label": "Kimi CLI",
        "enabled": false,
        "command": "kimi",
        "args": [],
        "handoffArgs": [],
        "integrationType": "pty_with_bootstrap_input",
        "bootstrapInput": "Read the keepitmovin handoff at {{handoffPath}} and continue the session (keep that file updated as you work).\n",
        "handoffBootstrapInput": "Read the keepitmovin handoff at {{handoffPath}} first, then continue from where the previous tool left off.\n",
        "controllable": true,
        "limitPatterns": [
          "[provider.rate_limit]",
          "membership expired, please renew your plan",
          "rate_limit_reached_error",
          "exceeded_current_quota_error",
          "engine_overloaded_error",
          "request reached organization",
          "is suspended due to insufficient balance",
          "reached your usage limit for this billing cycle"
        ]
      },
      {
        "name": "antigravity",
        "label": "Google Antigravity",
        "enabled": false,
        "command": "agy",
        "args": [
          "--prompt-interactive",
          "{{sessionPrompt}}"
        ],
        "handoffArgs": [
          "--prompt-interactive",
          "{{handoffPrompt}}"
        ],
        "integrationType": "pty",
        "controllable": true,
        "limitPatterns": [
          "individual quota reached",
          "the model api is currently overloaded",
          "our servers are experiencing high traffic right now"
        ]
      },
      {
        "name": "opencode",
        "label": "opencode",
        "enabled": false,
        "command": "opencode",
        "args": [
          "{{cwd}}",
          "--prompt",
          "{{sessionPrompt}}"
        ],
        "handoffArgs": [
          "{{cwd}}",
          "--prompt",
          "{{handoffPrompt}}"
        ],
        "integrationType": "pty",
        "controllable": true,
        "limitPatterns": [
          "provider is overloaded",
          "free usage exceeded, subscribe to go",
          "usage limit reached",
          "subscription quota exceeded",
          "gemini is way too hot right now"
        ]
      },
      {
        "name": "grok",
        "label": "Grok Build",
        "enabled": false,
        "command": "grok",
        "args": [
          "{{sessionPrompt}}"
        ],
        "handoffArgs": [
          "{{handoffPrompt}}"
        ],
        "integrationType": "pty",
        "controllable": true,
        "limitPatterns": [
          "hit the rate limit for your plan",
          "reached your free grok build usage limit",
          "free-usage-exhausted",
          "you hit your free usage limit",
          "you hit your weekly limit",
          "usage balance exhausted",
          "out of credits",
          "spending cap"
        ]
      },
      {
        "name": "cursor",
        "label": "Cursor Agent",
        "enabled": false,
        "command": "agent",
        "args": [
          "{{sessionPrompt}}"
        ],
        "handoffArgs": [
          "{{handoffPrompt}}"
        ],
        "integrationType": "pty",
        "controllable": true,
        "limitPatterns": [
          "you've hit your usage limit",
          "your usage limits will reset when your monthly cycle ends",
          "you've hit your free requests limit",
          "we're experiencing high demand"
        ]
      },
      {
        "name": "copilot",
        "label": "GitHub Copilot CLI",
        "enabled": false,
        "command": "copilot",
        "args": [],
        "handoffArgs": [],
        "integrationType": "pty_with_bootstrap_input",
        "bootstrapInput": "Read the keepitmovin handoff at {{handoffPath}} and continue the session (keep that file updated as you work).\n",
        "handoffBootstrapInput": "Read the keepitmovin handoff at {{handoffPath}} first, then continue from where the previous tool left off.\n",
        "controllable": true,
        "limitPatterns": [
          "hit a rate limit that restricts the number of copilot model requests",
          "reached your weekly rate limit",
          "exceeded your copilot token usage",
          "you have no quota",
          "quota_exceeded"
        ]
      },
      {
        "name": "ollama",
        "label": "Ollama",
        "enabled": false,
        "command": "ollama",
        "args": [
          "run",
          "llama3.2"
        ],
        "handoffArgs": [
          "run",
          "llama3.2"
        ],
        "integrationType": "pty_with_bootstrap_input",
        "bootstrapInput": "{{sessionPrompt}}\n",
        "handoffBootstrapInput": "{{handoffPrompt}}\n",
        "controllable": true
      },
      {
        "name": "cline",
        "label": "Cline",
        "enabled": false,
        "command": "cline",
        "args": [
          "-i",
          "{{sessionPrompt}}"
        ],
        "handoffArgs": [
          "-i",
          "{{handoffPrompt}}"
        ],
        "integrationType": "pty",
        "controllable": true
      },
      {
        "name": "aider",
        "label": "Aider",
        "enabled": false,
        "command": "aider",
        "args": [],
        "handoffArgs": [],
        "integrationType": "pty_with_bootstrap_input",
        "bootstrapInput": "Read the keepitmovin handoff at {{handoffPath}} and continue the session (keep that file updated as you work).\n",
        "handoffBootstrapInput": "Read the keepitmovin handoff at {{handoffPath}} first, then continue from where the previous tool left off.\n",
        "controllable": true
      },
      {
        "name": "goose",
        "label": "Goose",
        "enabled": false,
        "command": "goose",
        "args": [
          "session"
        ],
        "handoffArgs": [
          "session"
        ],
        "integrationType": "pty_with_bootstrap_input",
        "bootstrapInput": "Read the keepitmovin handoff at {{handoffPath}} and continue the session (keep that file updated as you work).\n",
        "handoffBootstrapInput": "Read the keepitmovin handoff at {{handoffPath}} first, then continue from where the previous tool left off.\n",
        "controllable": true
      },
      {
        "name": "amp",
        "label": "Amp",
        "enabled": false,
        "command": "amp",
        "args": [],
        "handoffArgs": [],
        "integrationType": "pty_with_bootstrap_input",
        "bootstrapInput": "Read the keepitmovin handoff at {{handoffPath}} and continue the session (keep that file updated as you work).\n",
        "handoffBootstrapInput": "Read the keepitmovin handoff at {{handoffPath}} first, then continue from where the previous tool left off.\n",
        "controllable": true
      },
      {
        "name": "droid",
        "label": "Factory Droid",
        "enabled": false,
        "command": "droid",
        "args": [
          "{{sessionPrompt}}"
        ],
        "handoffArgs": [
          "{{handoffPrompt}}"
        ],
        "integrationType": "pty",
        "controllable": true
      }
    ]
  }
}
