{
  "updates": {
    "checkOnStart": false,
    "mode": "off"
  },
  "routing": {
    "enabled": false
  },
  "harness": {
    "setupComplete": true,
    "providerOrder": ["claude", "codex"],
    "usageProbe": {
      "enabled": false
    },
    "watchdog": {
      "enabled": false,
      "action": "warn"
    },
    "providers": [
      {
        "name": "claude",
        "label": "Claude Code",
        "enabled": true,
        "command": "claude",
        "args": ["--permission-mode", "acceptEdits", "{{sessionPrompt}}"],
        "handoffArgs": ["{{handoffPrompt}}"],
        "integrationType": "pty"
      },
      {
        "name": "codex",
        "label": "Codex",
        "enabled": true,
        "command": "codex",
        "args": ["{{sessionPrompt}}"],
        "handoffArgs": ["{{handoffPrompt}}"],
        "integrationType": "pty"
      }
    ]
  }
}
