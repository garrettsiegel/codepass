---
import "@fontsource/instrument-sans/400.css";
import "@fontsource/instrument-sans/500.css";
import "@fontsource/instrument-sans/600.css";
import "@fontsource/instrument-sans/700.css";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/600.css";
import Analytics from "@vercel/analytics/astro";
import "../styles/design-system.css";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION?.trim();
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/opengraph.png", Astro.site);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "keepitmovin",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "macOS, Linux, Windows",
  description,
  url: "https://www.keepitmovin.dev",
  downloadUrl: "https://www.npmjs.com/package/keepitmovin",
  license: "https://github.com/garrettsiegel/keepitmovin/blob/main/LICENSE",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {googleSiteVerification && <meta name="google-site-verification" content={googleSiteVerification} />}
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="theme-color" content="#0f0d0b" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="keepitmovin" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a class="wordmark" href="/"><span class="glyph">»</span>keepitmovin</a>
        <nav class="site-nav">
          <a href="/docs">Docs</a>
          <a
            href="https://github.com/garrettsiegel/keepitmovin"
            target="_blank"
            rel="noopener">GitHub</a
          >
          <a
            class="nav-cta"
            href="https://www.npmjs.com/package/keepitmovin"
            target="_blank"
            rel="noopener">Install</a
          >
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="footer-card">
          <div class="footer-brand">
            <a class="wordmark" href="/"><span class="glyph">»</span>keepitmovin</a>
            <p class="tagline">Never stop mid-task again.</p>
          </div>
          <nav class="footer-col" aria-label="Product">
            <h4>Product</h4>
            <a href="/docs">Docs</a>
            <a href="/#pricing">Pricing</a>
            <a href="/compare">Compare</a>
            <a href="/blog">Blog</a>
            <a href="/changelog">Changelog</a>
            <a
              href="https://www.npmjs.com/package/keepitmovin"
              target="_blank"
              rel="noopener">npm</a
            >
          </nav>
          <nav class="footer-col" aria-label="Project">
            <h4>Project</h4>
            <a
              href="https://github.com/garrettsiegel/keepitmovin"
              target="_blank"
              rel="noopener">GitHub</a
            >
            <a
              href="https://github.com/garrettsiegel/keepitmovin/blob/main/LICENSE"
              target="_blank"
              rel="noopener">License: MIT</a
            >
            <a
              href="https://github.com/garrettsiegel/keepitmovin/blob/main/SECURITY.md"
              target="_blank"
              rel="noopener">Security</a
            >
            <a href="/privacy">Privacy</a>
          </nav>
          <nav class="footer-col" aria-label="Contact">
            <h4>Contact</h4>
            <a href="mailto:garrett@garrettsiegel.com">garrett@garrettsiegel.com</a>
            <a
              href="https://github.com/garrettsiegel/keepitmovin/issues"
              target="_blank"
              rel="noopener">Issues</a
            >
          </nav>
        </div>
        <p class="footer-bottom">© 2026 keepitmovin</p>
      </div>
    </footer>
    <Analytics />
  </body>
</html>
