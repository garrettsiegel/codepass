---
import {
  DEFAULT_HERO_FLOW_SETTINGS,
  type HeroFlowSettings,
} from "../lib/hero-flow-settings";

type Control = {
  key: keyof HeroFlowSettings;
  label: string;
  min: number;
  max: number;
  step: number;
  unit?: string;
};

const groups: Array<{ label: string; controls: Control[] }> = [
  {
    label: "Motion",
    controls: [
      { key: "frameRate", label: "Frame rate", min: 12, max: 60, step: 1, unit: " fps" },
      { key: "speed", label: "Speed", min: 0, max: 2, step: 0.05, unit: "×" },
    ],
  },
  {
    label: "Grid",
    controls: [
      { key: "cellSpacing", label: "Cell spacing", min: 12, max: 32, step: 1, unit: " px" },
      { key: "maxCells", label: "Cell limit", min: 800, max: 6000, step: 100 },
    ],
  },
  {
    label: "Ribbon shape",
    controls: [
      { key: "ribbonWidth", label: "Width", min: 0.4, max: 2, step: 0.05, unit: "×" },
      { key: "ribbonAmplitude", label: "Wave height", min: 0.25, max: 1.75, step: 0.05, unit: "×" },
      { key: "detail", label: "Detail", min: 0.4, max: 2, step: 0.05, unit: "×" },
    ],
  },
  {
    label: "Glyphs",
    controls: [
      { key: "visibilityThreshold", label: "Visibility threshold", min: 0.02, max: 0.45, step: 0.01 },
      { key: "opacity", label: "Maximum opacity", min: 0.05, max: 0.6, step: 0.01 },
      { key: "baseGlyphSize", label: "Base size", min: 5, max: 14, step: 0.5, unit: " px" },
      { key: "glyphSizeRange", label: "Size variation", min: 0, max: 10, step: 0.5, unit: " px" },
      { key: "accentThreshold", label: "Accent threshold", min: 0.3, max: 1, step: 0.01 },
      { key: "accentEvery", label: "Accent spacing", min: 2, max: 40, step: 1, unit: " cells" },
    ],
  },
  {
    label: "Readability",
    controls: [
      { key: "vignetteStrength", label: "Center mask", min: 0, max: 1, step: 0.01 },
    ],
  },
];
---

<aside class="hero-editor" data-hero-editor hidden aria-label="Hero animation editor">
  <header class="hero-editor-header">
    <div>
      <p class="hero-editor-kicker">Hero animation lab</p>
      <h2>Shape the glyph field</h2>
    </div>
    <button class="hero-editor-close" type="button" data-hero-editor-close aria-label="Close editor">×</button>
  </header>

  <p class="hero-editor-note">Changes are live and saved in this browser.</p>

  <form data-hero-editor-form>
    {
      groups.map((group) => (
        <fieldset class="hero-editor-group">
          <legend>{group.label}</legend>
          {group.controls.map((control) => {
            const id = `hero-flow-${control.key}`;
            return (
              <label class="hero-editor-control" for={id}>
                <span>
                  {control.label}
                  <output for={id} data-setting-output={control.key}>
                    {DEFAULT_HERO_FLOW_SETTINGS[control.key]}{control.unit}
                  </output>
                </span>
                <input
                  id={id}
                  name={control.key}
                  type="range"
                  min={control.min}
                  max={control.max}
                  step={control.step}
                  value={DEFAULT_HERO_FLOW_SETTINGS[control.key]}
                  data-setting-input
                  data-unit={control.unit ?? ""}
                />
              </label>
            );
          })}
        </fieldset>
      ))
    }

    <div class="hero-editor-actions">
      <button class="btn btn-primary" type="button" data-copy-settings>Copy settings</button>
      <button class="btn btn-ghost" type="button" data-reset-settings>Reset</button>
    </div>

    <label class="hero-editor-export-label" for="hero-flow-export">Settings JSON</label>
    <textarea id="hero-flow-export" data-settings-export readonly rows="12"></textarea>
  </form>
</aside>

<script>
  import {
    DEFAULT_HERO_FLOW_SETTINGS,
    HERO_FLOW_SETTINGS_VERSION,
    normalizeHeroFlowSettings,
    type HeroFlowSettings,
  } from "../lib/hero-flow-settings";

  const editor = document.querySelector<HTMLElement>("[data-hero-editor]");
  const editorEnabled = new URLSearchParams(window.location.search).get("hero-editor") === "true";

  if (editor && editorEnabled) {
    const form = editor.querySelector<HTMLFormElement>("[data-hero-editor-form]");
    const exportField = editor.querySelector<HTMLTextAreaElement>("[data-settings-export]");
    const inputs = Array.from(editor.querySelectorAll<HTMLInputElement>("[data-setting-input]"));
    const storageKey = "keepitmovin:hero-flow-editor:v1";

    const readForm = () => {
      const values: Partial<HeroFlowSettings> = {};
      inputs.forEach((input) => {
        const key = input.name as keyof HeroFlowSettings;
        values[key] = Number(input.value);
      });
      return normalizeHeroFlowSettings(values);
    };

    const updateOutputs = () => {
      inputs.forEach((input) => {
        const output = editor.querySelector<HTMLOutputElement>(
          `[data-setting-output="${input.name}"]`,
        );
        if (output) output.textContent = `${input.value}${input.dataset.unit ?? ""}`;
      });
    };

    const createExport = (settings: HeroFlowSettings) =>
      JSON.stringify(
        {
          schemaVersion: HERO_FLOW_SETTINGS_VERSION,
          component: "hero-flow",
          settings,
        },
        null,
        2,
      );

    const applySettings = (settings: HeroFlowSettings, persist = true) => {
      inputs.forEach((input) => {
        const key = input.name as keyof HeroFlowSettings;
        input.value = String(settings[key]);
      });
      updateOutputs();
      if (exportField) exportField.value = createExport(settings);
      window.dispatchEvent(
        new CustomEvent("keepitmovin:hero-flow-settings", { detail: settings }),
      );
      if (persist) localStorage.setItem(storageKey, JSON.stringify(settings));
    };

    let initialSettings = DEFAULT_HERO_FLOW_SETTINGS;
    try {
      const stored = localStorage.getItem(storageKey);
      if (stored) initialSettings = normalizeHeroFlowSettings(JSON.parse(stored));
    } catch {
      localStorage.removeItem(storageKey);
    }

    editor.hidden = false;
    document.documentElement.classList.add("hero-editor-open");
    applySettings(initialSettings, false);

    form?.addEventListener("input", () => applySettings(readForm()));

    editor.querySelector("[data-reset-settings]")?.addEventListener("click", () => {
      localStorage.removeItem(storageKey);
      applySettings(DEFAULT_HERO_FLOW_SETTINGS, false);
    });

    const copyButton = editor.querySelector<HTMLButtonElement>("[data-copy-settings]");
    copyButton?.addEventListener("click", async () => {
      if (!exportField) return;
      try {
        await navigator.clipboard.writeText(exportField.value);
      } catch {
        exportField.select();
        document.execCommand("copy");
      }
      copyButton.textContent = "Copied";
      window.setTimeout(() => {
        copyButton.textContent = "Copy settings";
      }, 1200);
    });

    editor.querySelector("[data-hero-editor-close]")?.addEventListener("click", () => {
      const url = new URL(window.location.href);
      url.searchParams.delete("hero-editor");
      window.history.replaceState({}, "", url);
      editor.hidden = true;
      document.documentElement.classList.remove("hero-editor-open");
    });
  }
</script>

<style>
  .hero-editor[hidden] {
    display: none;
  }

  .hero-editor {
    position: fixed;
    z-index: 80;
    top: 5.25rem;
    right: 1rem;
    width: min(23rem, calc(100vw - 2rem));
    max-height: calc(100vh - 6.25rem);
    overflow-y: auto;
    padding: 1rem;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--bg-raised) 92%, transparent);
    box-shadow: 0 1.5rem 4rem rgba(0, 0, 0, 0.28);
    color: var(--text);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }

  .hero-editor-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .hero-editor-kicker,
  .hero-editor-header h2,
  .hero-editor-note {
    margin: 0;
  }

  .hero-editor-kicker,
  .hero-editor-group legend,
  .hero-editor-export-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .hero-editor-header h2 {
    margin-top: 0.15rem;
    font-size: 1.1rem;
    line-height: 1.25;
  }

  .hero-editor-close {
    display: grid;
    width: 2rem;
    height: 2rem;
    place-items: center;
    padding: 0;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: transparent;
    color: var(--text-dim);
    font: inherit;
    cursor: pointer;
    transition: color 150ms ease, border-color 150ms ease, transform 150ms ease;
  }

  .hero-editor-close:hover {
    color: var(--text);
    border-color: var(--line-strong);
  }

  .hero-editor-close:active,
  .hero-editor-actions .btn:active {
    transform: scale(0.97);
  }

  .hero-editor-note {
    margin-top: 0.55rem;
    font-size: 0.82rem;
    color: var(--text-dim);
  }

  .hero-editor-group {
    display: grid;
    gap: 0.75rem;
    margin: 1rem 0 0;
    padding: 0.85rem 0 0;
    border: 0;
    border-top: 1px solid var(--line);
  }

  .hero-editor-group legend {
    padding: 0 0.5rem 0 0;
  }

  .hero-editor-control {
    display: grid;
    gap: 0.25rem;
    font-size: 0.82rem;
  }

  .hero-editor-control > span {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  .hero-editor-control output {
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .hero-editor-control input {
    width: 100%;
    accent-color: var(--accent);
  }

  .hero-editor-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .hero-editor-actions .btn {
    justify-content: center;
    flex: 1;
    padding-inline: 0.8rem;
  }

  .hero-editor-export-label {
    display: block;
    margin-top: 1rem;
  }

  .hero-editor textarea {
    display: block;
    width: 100%;
    margin-top: 0.4rem;
    padding: 0.75rem;
    resize: vertical;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--bg-inset);
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    line-height: 1.45;
  }

  @media (max-width: 600px) {
    .hero-editor {
      top: 4.75rem;
      right: 0.75rem;
      max-height: calc(100vh - 5.5rem);
      width: calc(100vw - 1.5rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-editor-close {
      transition: none;
    }
  }
</style>
