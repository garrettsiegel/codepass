{
  "fallbackOn": [
    "rate_limit",
    "quota_exceeded",
    "auth_error",
    "timeout",
    "command_not_found",
    "nonzero_exit"
  ],
  "context": {
    "maxDiffChars": 20000
  },
  "logs": {
    "sessionsDir": ".codepass/sessions"
  },
  "updates": {
    "checkOnStart": true,
    "mode": "prompt",
    "includeDisabledProviders": false
  },
  "routing": {
    "enabled": false,
    "promptForTask": true,
    "allowOverride": true,
    "askOutcome": true,
    "telemetry": true
  },
  "harness": {
    "setupComplete": false,
    "providerOrder": ["claude", "codex", "antigravity", "opencode"],
    "transcriptLimitChars": 80000,
    "handoffPath": ".codepass/current/handoff.md",
    "handoffArchiveDir": ".codepass/handoffs",
    "manualSwitchKey": "ctrl-]",
    "autoAppendCheckpoints": true,
    "providers": [
      {
        "name": "claude",
        "label": "Claude Code",
        "enabled": true,
        "command": "claude",
        "args": ["{{sessionPrompt}}"],
        "handoffArgs": ["{{handoffPrompt}}"],
        "integrationType": "pty",
        "controllable": true
      },
      {
        "name": "codex",
        "label": "Codex",
        "enabled": true,
        "command": "codex",
        "args": ["{{sessionPrompt}}"],
        "handoffArgs": ["{{handoffPrompt}}"],
        "integrationType": "pty",
        "controllable": true
      },
      {
        "name": "cline",
        "label": "Cline",
        "enabled": false,
        "command": "cline",
        "args": ["{{sessionPrompt}}"],
        "handoffArgs": ["{{handoffPrompt}}"],
        "integrationType": "pty",
        "controllable": true
      },
      {
        "name": "antigravity",
        "label": "Google Antigravity",
        "enabled": true,
        "command": "agy",
        "args": ["--prompt-interactive", "{{sessionPrompt}}"],
        "handoffArgs": ["--prompt-interactive", "{{handoffPrompt}}"],
        "integrationType": "pty",
        "controllable": true
      },
      {
        "name": "opencode",
        "label": "opencode",
        "enabled": true,
        "command": "opencode",
        "args": ["{{cwd}}", "--prompt", "{{sessionPrompt}}"],
        "handoffArgs": ["{{cwd}}", "--prompt", "{{handoffPrompt}}"],
        "integrationType": "pty",
        "controllable": true
      }
    ]
  }
}
